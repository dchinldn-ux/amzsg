name: Daily Amazon.sg Price Monitor

on:
  schedule:
    # 01:00 UTC = 09:00 Singapore time
    - cron: "0 1 * * *"
  workflow_dispatch:

permissions:
  contents: write

jobs:
  check-price:
    runs-on: ubuntu-latest

    steps:
      - name: Check out repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: pip install -r requirements.txt

      - name: Run price check
        run: python price_monitor.py

      - name: Commit updated price history
        run: |
          git config --global user.name "price-monitor-bot"
          git config --global user.email "price-monitor-bot@users.noreply.github.com"
          git add amazon_sg_price_history.csv
          git commit -m "Update Amazon.sg price history" || echo "No changes to commit"
          git push

